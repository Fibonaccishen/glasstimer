{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlassTimer",
  "version": "1.0.0",
  "identifier": "com.glasstimer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GlassTimer",
        "width": 280,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true
      }
    ]
  }
}
